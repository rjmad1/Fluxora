# ==========================================
# Fluxora — Unified Configuration Reference
# ==========================================

# 1. Transactional Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:change-me-in-production@localhost:54321/fluxora_db?schema=public"

# 2. Redis Queue
REDIS_HOST="localhost"
REDIS_PORT=6379

# 3. Secrets Management (HashiCorp Vault)
VAULT_URL="http://localhost:8200"
VAULT_TOKEN="fluxora-dev-token"
ENCRYPTION_KEY="57652061726520746865206368616d70696f6e73206d7920667269656e642121" # 32-byte hex encryption fallback key

# 4. Identity & Auth (Keycloak)
KEYCLOAK_SERVER_URL="http://localhost:8081/auth"
KEYCLOAK_REALM="fluxora"
KEYCLOAK_CLIENT_ID="backend"
KEYCLOAK_CLIENT_SECRET="secret"

# 5. API Ingress Gateway (Kong / Local Dev)
PORT=3000
# Client Approval Portal — MUST be overridden in production (min 32 random bytes, hex or base64)
PORTAL_SECRET_KEY="CHANGE_ME_generate_with_openssl_rand_hex_32"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# 6. Event Mesh (Apache Kafka)
KAFKA_BROKERS="localhost:9092"
KAFKA_CLIENT_ID="fluxora-backend"
KAFKA_FALLBACK="true" # Set to "true" to fallback to local json log files if Kafka is offline

# 7. Analytics Columnar Database (ClickHouse)
CLICKHOUSE_URL="http://localhost:8123"
CLICKHOUSE_USER="default"
CLICKHOUSE_PASSWORD=""
CLICKHOUSE_DATABASE="default"

# 8. Asset Storage (MinIO / S3)
S3_BUCKET="fluxora-assets"
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minio-admin"
S3_SECRET_KEY="minio-admin-secret"
S3_REGION="us-east-1"
S3_FORCE_PATH_STYLE="true"

# 9. Workflow Orchestration (Temporal)
TEMPORAL_ADDRESS="localhost:7233"
TEMPORAL_NAMESPACE="default"

# 10. AI Service Integrations
OPENAI_API_KEY=""
GEMINI_API_KEY=""
QDRANT_URL="http://localhost:6333"

# 11. Third Party Services
RESEND_API_KEY="re_123456789"
MAIL_FROM="Fluxora <no-reply@fluxora.social>"
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
PROXY_URL=""
